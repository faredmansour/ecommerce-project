{
  "name": "alfredo-ecommerce-api",
  "version": "1.0.0",
  "description": "Alfredo E-Commerce REST API — Node.js, Express, MongoDB. Auth (JWT + refresh), products, cart, orders, payments (Stripe), reviews, wishlist, coupons, addresses.",
  "main": "app.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch --runInBand"
  },
  "keywords": [
    "ecommerce",
    "express",
    "mongodb",
    "rest-api",
    "stripe",
    "jwt"
  ],
  "author": "Fared Mansour",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.39.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.4",
    "redis": "^4.7.0",
    "stripe": "^12.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.2.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
