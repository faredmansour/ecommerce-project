{
  "info": {
    "name": "Alfredo E-Commerce API",
    "_postman_id": "alfredo-ecommerce-2024",
    "description": "Complete API collection for Alfredo E-Commerce project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" },
    { "key": "adminToken", "value": "",                   "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [

        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mohamed User\",\n  \"email\": \"user@test.com\",\n  \"password\": \"user1234\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
            ]}
          }]
        },

        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Admin\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"admin1234\",\n  \"role\": \"admin\",\n  \"adminSecret\": \"ADMIN_SECRET_2024\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Role is admin', () => pm.expect(pm.response.json().user.role).to.eql('admin'));"
            ]}
          }]
        },

        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"user1234\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has token', () => { const json = pm.response.json(); pm.expect(json).to.have.property('token'); pm.collectionVariables.set('token', json.token); });"
            ]}
          }]
        },

        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"admin1234\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Save admin token', () => { const json = pm.response.json(); pm.collectionVariables.set('adminToken', json.token); });"
            ]}
          }]
        },

        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has email', () => pm.expect(pm.response.json()).to.have.property('email'));"
            ]}
          }]
        },

        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mohamed Updated\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Name updated', () => pm.expect(pm.response.json().user.name).to.include('UPDATED'));"
            ]}
          }]
        },

        {
          "name": "❌ Login Wrong Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"] }
          }]
        },

        {
          "name": "❌ Get Profile No Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
          }]
        },

        {
          "name": "❌ Register Admin Wrong Secret",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fake Admin\",\n  \"email\": \"fake@test.com\",\n  \"password\": \"fake1234\",\n  \"role\": \"admin\",\n  \"adminSecret\": \"WRONG_KEY\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 403', () => pm.response.to.have.status(403));"] }
          }]
        }

      ]
    },

    {
      "name": "📦 Products",
      "item": [

        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}
          }]
        },

        {
          "name": "Get Products by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?category=Electronics",
              "host": ["{{baseUrl}}"], "path": ["api","products"],
              "query": [{ "key": "category", "value": "Electronics" }]
            }
          }
        },

        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?search=phone",
              "host": ["{{baseUrl}}"], "path": ["api","products"],
              "query": [{ "key": "search", "value": "phone" }]
            }
          }
        },

        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api","products",":id"],
              "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        },

        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 15\",\n  \"price\": 999,\n  \"category\": \"Electronics\",\n  \"description\": \"Latest iPhone model\",\n  \"stock\": 50\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"] }
          }]
        },

        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api","products",":id"],
              "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 899,\n  \"stock\": 45\n}"
            }
          }
        },

        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api","products",":id"],
              "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        }

      ]
    },

    {
      "name": "🗂️ Categories",
      "item": [

        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api","categories"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}
          }]
        },

        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api","categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic devices and gadgets\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"] }
          }]
        },

        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/categories/:id", "host": ["{{baseUrl}}"], "path": ["api","categories",":id"],
              "variable": [{ "key": "id", "value": "CATEGORY_ID_HERE" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics & Gadgets\"\n}"
            }
          }
        },

        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/categories/:id", "host": ["{{baseUrl}}"], "path": ["api","categories",":id"],
              "variable": [{ "key": "id", "value": "CATEGORY_ID_HERE" }]
            }
          }
        }

      ]
    }

  ]
}
