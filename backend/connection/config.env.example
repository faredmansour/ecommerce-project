# ── Copy this file to config.env and fill in real values ──
# The app loads env from ./connection/config.env

# Core
PORT=8000
NODE_ENV=development
DB_URL="mongodb://127.0.0.1:27017/alfredo-ecommerce"

# Auth (JWT)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m

# Frontend origins (comma-separated). Used for CORS and password-reset links.
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Optional integrations (left blank = feature gracefully disabled) ──

# Redis caching (product listings). Leave empty to skip caching.
REDIS_URL=

# Stripe payments. Without this, /api/payments/intent errors and the
# frontend falls back to Cash on Delivery.
STRIPE_SECRET_KEY=

# Cloudinary image hosting. Without all three, uploads stay on local disk.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=alfredo-store

# SMTP email (password-reset). Without these, forgot-password emails fail.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Alfredo Store <no-reply@alfredo.test>"
